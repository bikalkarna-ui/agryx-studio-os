# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# OpenRouter (AI quotes, follow-ups, review messages, landing page copy, photo culling)
OPENROUTER_API_KEY=

# Resend — real email sending (resend.com). Free tier is plenty to start.
RESEND_API_KEY=
RESEND_FROM_EMAIL=studio@yourdomain.com

# Twilio — real SMS sending (twilio.com). Optional — falls back to email if unset.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
